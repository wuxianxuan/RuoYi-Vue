<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.StockRecommendMapper">

    <resultMap type="com.ruoyi.system.domain.stock.StockRecommend" id="StockRecommendResult">
        <result property="id"            column="id"/>
        <result property="recommendDate" column="recommend_date"/>
        <result property="stockId"       column="stock_id"/>
        <result property="stockCode"     column="stock_code"/>
        <result property="stockName"     column="stock_name"/>
        <result property="totalScore"    column="total_score"/>
        <result property="trendScore"    column="trend_score"/>
        <result property="plateScore"    column="plate_score"/>
        <result property="fundScore"     column="fund_score"/>
        <result property="baseScore"     column="base_score"/>
        <result property="reason"        column="reason"/>
        <result property="status"        column="status"/>
        <result property="createBy"      column="create_by"/>
        <result property="createTime"    column="create_time"/>
        <result property="updateBy"      column="update_by"/>
        <result property="updateTime"    column="update_time"/>
        <result property="remark"        column="remark"/>
    </resultMap>

    <sql id="selectRecommendVo">
        select id, recommend_date, stock_id, stock_code, stock_name,
               total_score, trend_score, plate_score, fund_score, base_score,
               reason, status, create_by, create_time, update_by, update_time, remark
        from stock_recommend
    </sql>

    <insert id="batchInsertRecommend">
        insert into stock_recommend (
            recommend_date, stock_id, stock_code, stock_name,
            total_score, trend_score, plate_score, fund_score, base_score,
            reason, status, create_by, create_time, update_by, update_time
        ) values
        <foreach collection="list" item="item" separator=",">
            (#{item.recommendDate}, #{item.stockId}, #{item.stockCode}, #{item.stockName},
             #{item.totalScore}, #{item.trendScore}, #{item.plateScore},
             #{item.fundScore}, #{item.baseScore},
             #{item.reason}, #{item.status},
             #{item.createBy}, sysdate(), #{item.updateBy}, sysdate())
        </foreach>
    </insert>

    <select id="selectByDate" resultMap="StockRecommendResult">
        <include refid="selectRecommendVo"/>
        where recommend_date = #{recommendDate}
        order by total_score desc
    </select>

    <delete id="deleteByDate">
        delete from stock_recommend where recommend_date = #{recommendDate}
    </delete>

</mapper>
